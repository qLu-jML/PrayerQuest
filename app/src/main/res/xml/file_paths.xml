<?xml version="1.0" encoding="utf-8"?>
<paths xmlns:android="http://schemas.android.com/apk/res/android">
    <!--
      Shared-cache paths exposed via FileProvider so we can emit Uris that
      other apps can read (e.g. the system Share Sheet for testimony card
      bitmaps generated by the Big Celebration Moment — DD §3.5.2).

      Scoped to "shared/" so the rest of the cache directory remains
      private; the celebration code writes into
      cacheDir/shared/celebration/<id>.png and rest of the app stays
      isolated.
    -->
    <cache-path
        name="shared_cache"
        path="shared/" />

    <!--
      Gratitude & testimony photos live in app-private files-dir per
      DD §3.6 guarantees; if we ever share those externally in the future
      they'll live here.
    -->
    <files-path
        name="shared_files"
        path="shared/" />
</paths>
